{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "out",
    "baseUrl": ".",
    "paths": {}
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules", "out", "dist"]
}
